# Copy this file to secrets.toml and fill in real values.
# NEVER commit secrets.toml to git.

[credentials.usernames.mathieu]
email = "mathieu@example.com"
name = "Mathieu"
password = "$2b$12$REPLACE_WITH_BCRYPT_HASH"

[cookie]
name = "psim_auth"
key = "replace-with-a-random-secret-key"
expiry_days = 30

[database]
url = "postgresql://user:password@db.xxx.supabase.co:5432/postgres"
