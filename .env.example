# Portfolio Simulator Configuration
# Copy to .env and fill in values as needed

# Default data provider: "yahoo" (default), "csv", or future: "reuters", "bloomberg"
# PSIM_DEFAULT_PROVIDER=yahoo

# Cache directory (default: ~/.portfolio_simulator)
# PSIM_CACHE_DIR=~/.portfolio_simulator

# Cache TTL in hours (default: 24)
# PSIM_CACHE_TTL_HOURS=24

# Default currency for portfolio valuation
# PSIM_DEFAULT_CURRENCY=USD

# Risk-free rate for Sharpe ratio etc. (annualized, decimal)
# PSIM_RISK_FREE_RATE=0.02

# Max concurrent data fetches (default: 10)
# PSIM_MAX_CONCURRENT_FETCHES=10

# Future: premium data provider API keys
# PSIM_BLOOMBERG_API_KEY=
# PSIM_REUTERS_API_KEY=
